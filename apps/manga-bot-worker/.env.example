# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_OWNER_USER_ID=

# Existing web application. The session token is APP_SESSION_TOKEN from it.
MANGA_APP_URL=
MANGA_APP_SESSION_TOKEN=

# Internal or public URL of the Kindle uploader service in Yandex Cloud.
KINDLE_WORKER_URL=
KINDLE_SHARED_SECRET=

# Optional public URL for setting the Telegram webhook.
PUBLIC_BASE_URL=
PORT=3000
DATA_DIR=/data
# Rendered page-asset target; keeps margin below Send to Kindle's hard limit.
MAX_PDF_BYTES=150000000
# Process one chapter at a time to stay below the upstream request limit.
CHAPTER_PROCESSING_CONCURRENCY=1
# Render image spreads and package at most two split EPUB volumes at a time.
EPUB_BUILD_CONCURRENCY=2
# Stage at most two completed EPUB volumes in the Kindle queue at a time.
KINDLE_UPLOAD_CONCURRENCY=2

# Shared analytics API and password-protected dashboard at /analytics.
ANALYTICS_INGEST_TOKEN=
ANALYTICS_DASHBOARD_USERNAME=admin
ANALYTICS_DASHBOARD_PASSWORD=
