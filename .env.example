# Telegram bot settings
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=

# Existing web application. The session token is APP_SESSION_TOKEN from it.
MANGA_APP_URL=https://manga-pdf-processor-production.up.railway.app
MANGA_APP_SESSION_TOKEN=

# Existing Kindle uploader service (prefer its Railway private URL).
KINDLE_WORKER_URL=
KINDLE_SHARED_SECRET=

# Optional public URL for setting the Telegram webhook.
PUBLIC_BASE_URL=
PORT=3000
DATA_DIR=/data
MAX_PDF_BYTES=193986560
